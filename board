/* ═══════════════════════════════════════════════════════════════════
   CONSTANTS
   ═══════════════════════════════════════════════════════════════════ */

const STAGES = ['DISPATCHER', 'SCENARIO', 'PAYLOAD', 'CONNECT', 'EVENT_STORE'];
const KAFKA_TOPICS = ['T24.RAW', 'T24.PROCESSED', 'FX.TRADES', 'PAYMENT.IN', 'POSITION.UPD'];
const TX_TYPES = ['FX_TRADE', 'PAYMENT', 'TRANSFER', 'POSITION_UPDATE', 'SETTLEMENT', 'RECONCILIATION'];

const ERR_MSGS = {
  DISPATCHER: ['Routing timeout — no matching scenario', 'Queue overflow — message dropped', 'Schema validation failed'],
  SCENARIO: ['Validation rule violation in scenario', 'Null pointer in condition eval', 'Registry timeout'],
  PAYLOAD: ['Schema mismatch at field mapping', 'Required field missing from source', 'Unexpected data type in payload'],
  CONNECT: ['Service unavailable — connection refused', 'Kafka broker not reachable', 'Connection pool exhausted'],
  EVENT_STORE: ['Storage quota exceeded', 'Duplicate event detected', 'Latency threshold exceeded'],
};

const STAGE_LOGS = {
  DISPATCHER: (id, t) => `DISPATCHER >> [${id}] Routing to ${t} scenario pipeline`,
  SCENARIO: (id, t) => `SCENARIO >> [${id}] Scenario ${t}_FLOW matched and executed`,
  PAYLOAD: (id) => `PAYLOAD >> [${id}] Payload transformed (${Math.floor(Math.random() * 50 + 10)} fields)`,
  CONNECT: (id, _t, tp) => `CONNECT >> [${id}] Connected to downstream via ${tp || 'default'}`,
  EVENT_STORE: (id) => `EVENT_STORE >> [${id}] Persisted to event store ✓`,
};

/* ═══════════════════════════════════════════════════════════════════
   ZUSTAND STORE (Single Source of Truth)
   ═══════════════════════════════════════════════════════════════════ */

const emptyNodes = () => ({
  DISPATCHER: { total: 0, success: 0, error: 0, processing: 0 },
  SCENARIO: { total: 0, success: 0, error: 0, processing: 0 },
  PAYLOAD: { total: 0, success: 0, error: 0, processing: 0 },
  CONNECT: { total: 0, success: 0, error: 0, processing: 0 },
  EVENT_STORE: { total: 0, success: 0, error: 0, processing: 0 },
});

const emptyMetrics = () => ({
  totalVolume: 0,
  successCount: 0,
  errorCount: 0,
  processingCount: 0,
  healthPercent: 100,
  activeIssues: 0,
  nodes: emptyNodes(),
});

let _lc = 0;
let _ic = 0;

const useStore = create((set, get) => ({
  txs: [],
  logs: [],
  incs: [],
  m: emptyMetrics(),
  running: false,

  addTx: (t) => set((s) => ({ txs: [t, ...s.txs].slice(0, 50) })),
  updTx: (id, u) => set((s) => ({ txs: s.txs.map((t) => (t.id === id ? { ...t, ...u } : t)) })),
  addLog: (l) => {
    _lc++;
    set((s) => ({ logs: [...s.logs, { ...l, id: `l${_lc}` }].slice(-200) }));
  },
  addInc: (i) => {
    _ic++;
    set((s) => ({ incs: [{ ...i, id: `i${_ic}` }, ...s.incs].slice(0, 30) }));
  },
  setRun: (r) => set({ running: r }),
  reset: () => {
    _lc = 0;
    _ic = 0;
    set({ txs: [], logs: [], incs: [], running: false, m: emptyMetrics() });
  },

  recalc: () => {
    const { txs, incs } = get();
    const succ = txs.filter((t) => t.status === 'SUCCESS').length;
    const err = txs.filter((t) => t.status === 'ERROR').length;
    const proc = txs.filter((t) => t.status === 'PROCESSING').length;
    const done = succ + err;
    const nodes = {};
    for (const st of STAGES) {
      nodes[st] = {
        total: txs.filter(
          (t) =>
            t.completedStages.includes(st) ||
            (t.stage === st && t.status === 'PROCESSING') ||
            t.failedStage === st
        ).length,
        success: txs.filter((t) => t.completedStages.includes(st) && t.status !== 'ERROR').length,
        error: txs.filter((t) => t.failedStage === st).length,
        processing: txs.filter((t) => t.stage === st && t.status === 'PROCESSING').length,
      };
    }
    set({
      m: {
        totalVolume: txs.length,
        successCount: succ,
        errorCount: err,
        processingCount: proc,
        healthPercent: done > 0 ? Math.round((succ / done) * 100) : 100,
        activeIssues: incs.filter((i) => Date.now() - i.timestamp < 60000).length,
        nodes,
      },
    });
  },
}));

/* ═══════════════════════════════════════════════════════════════════
   SIMULATION ENGINE
   ═══════════════════════════════════════════════════════════════════ */

let _txC = 0;
let _timers = [];
let _genInt = null;

const rand = (a, b) => Math.floor(Math.random() * (b - a + 1)) + a;
const pick = (a) => a[Math.floor(Math.random() * a.length)];
const genTxId = () => {
  _txC++;
  return `GBM-${String(_txC).padStart(5, '0')}`;
};

function advance(id, si, tt, tp, done) {
  const S = useStore.getState();
  const tx = S.txs.find((t) => t.id === id);
  if (!tx || tx.status === 'ERROR') return;

  const st = STAGES[si];
  const nd = [...done, st];

  S.updTx(id, { stage: st, completedStages: nd });
  S.addLog({
    id: '',
    timestamp: Date.now(),
    message: STAGE_LOGS[st](id, tt, tp),
    level: 'INFO',
    txId: id,
    topic: st === 'CONNECT' ? tp : undefined,
  });

  if (st === 'CONNECT') {
    S.addLog({
      id: '',
      timestamp: Date.now(),
      message: `KAFKA >> [${id}] Published to ${tp} (partition ${rand(0, 7)})`,
      level: 'INFO',
      txId: id,
      topic: tp,
    });
  }

  S.recalc();

  const timer = setTimeout(() => {
    const c = useStore.getState();
    const ct = c.txs.find((t) => t.id === id);
    if (!ct || ct.status === 'ERROR') return;

    if (Math.random() < (st === 'EVENT_STORE' ? 0.02 : 0.1)) {
      const msg = pick(ERR_MSGS[st]);
      S.updTx(id, { status: 'ERROR', stage: st, error: msg, failedStage: st });
      S.addLog({
        id: '',
        timestamp: Date.now(),
        message: `${st} >> [${id}] ERROR: ${msg}`,
        level: 'ERROR',
        txId: id,
        topic: st === 'CONNECT' ? tp : undefined,
      });
      S.addInc({
        id: '',
        txId: id,
        txType: tt,
        failedStage: st,
        timestamp: Date.now(),
        errorMessage: `Failed at ${st}: ${msg}`,
      });
      S.recalc();
      return;
    }

    if (si < STAGES.length - 1) {
      advance(id, si + 1, tt, tp, nd);
    } else {
      S.updTx(id, {
        status: 'SUCCESS',
        stage: 'EVENT_STORE',
        completedStages: [...STAGES],
      });
      S.addLog({
        id: '',
        timestamp: Date.now(),
        message: `EVENT_STORE >> [${id}] Completed successfully ✓`,
        level: 'INFO',
        txId: id,
      });
      S.recalc();
    }
  }, rand(600, 1500));

  _timers.push(timer);
}

function spawn() {
  const S = useStore.getState();
  const id = genTxId();
  const tt = pick(TX_TYPES);
  const tp = pick(KAFKA_TOPICS);

  S.addTx({
    id,
    type: tt,
    stage: 'DISPATCHER',
    status: 'PROCESSING',
    timestamp: Date.now(),
    completedStages: [],
  });
  S.addLog({
    id: '',
    timestamp: Date.now(),
    message: `INGEST >> [${id}] Topic: ${tp} | Type: ${tt}`,
    level: 'INFO',
    txId: id,
    topic: tp,
  });
  S.recalc();
  advance(id, 0, tt, tp, []);
}

function startSim() {
  const S = useStore.getState();
  if (S.running) return;
  S.setRun(true);
  for (let i = 0; i < 3; i++) {
    const t = setTimeout(spawn, i * 300);
    _timers.push(t);
  }
  _genInt = setInterval(() => {
    const t = setTimeout(spawn, rand(1500, 3000));
    _timers.push(t);
  }, 1200);
}

function stopSim() {
  useDashboardStore.getState().setRun(false);
  if (_genInt) {
    clearInterval(_genInt);
    _genInt = null;
  }
  _timers.forEach(clearTimeout);
  _timers = [];
}

function resetSim() {
  stopSim();
  _txC = 0;
  useDashboardStore.getState().reset();
}

