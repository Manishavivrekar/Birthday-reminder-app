    <div className="bg-white/[0.02] border border-white/[0.06] rounded-2xl overflow-hidden">
      <div className="flex items-center gap-3 px-5 pt-4 pb-3">
        <span className="text-[10px] font-semibold uppercase tracking-[0.15em] text-white/30">Incidents</span>
        {incs.length > 0 && (
          <span className="px-1.5 py-0.5 rounded-md bg-rose-500/10 text-rose-400 text-[10px] font-semibold tabular-nums">
            {incs.length}
          </span>
        )}
        <div className="flex-1 h-px bg-white/[0.04]" />
      </div>
      <div className="max-h-[300px] overflow-y-auto dark-scrollbar px-5 pb-4">
        <AnimatePresence mode="popLayout">
          {incs.length > 0 ? (
            <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
              {incs.map((inc) => (
                <IncidentCard key={inc.id} inc={inc} />
              ))}
            </div>
          ) : (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="flex flex-col items-center justify-center py-12"
            >
              <ShieldAlert className="w-8 h-8 text-white/10 mb-3" />
              <span className="text-[12px] text-white/20 font-medium">No incidents</span>
              <span className="text-[10px] text-white/10 mt-1">All transactions processing normally</span>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════════════════════
   EVENT STREAM
   ═══════════════════════════════════════════════════════════════════ */

const TYPE_BADGE = {
  FX_TRADE: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  PAYMENT: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  TRANSFER: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
  POSITION_UPDATE: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  SETTLEMENT: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  RECONCILIATION: 'bg-pink-500/10 text-pink-400 border-pink-500/20',
};

const STATUS_ORDER = { PROCESSING: 0, ERROR: 1, SUCCESS: 2 };

function EventStream() {
  const txs = useDashboardStore((s) => s.txs);
  const sorted = [...txs].sort(
    (a, b) => (STATUS_ORDER[a.status] || 0) - (STATUS_ORDER[b.status] || 0)
  );

  return (
    <div className="bg-white/[0.02] border border-white/[0.06] rounded-2xl overflow-hidden">
      <div className="flex items-center gap-3 px-5 pt-4 pb-3">
        <span className="text-[10px] font-semibold uppercase tracking-[0.15em] text-white/30">
          Transaction Stream
        </span>
        <span className="text-[10px] font-mono text-white/20 tabular-nums">{txs.length} records</span>
        <div className="flex-1 h-px bg-white/[0.04]" />
      </div>

      {/* Table Header */}
      <div className="flex items-center gap-4 px-5 py-2 border-b border-white/[0.04]">
        <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/20 w-[100px]">TX ID</span>
        <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/20 w-[100px]">Type</span>
        <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/20 w-[80px]">Pipeline</span>
        <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/20 w-[60px]">Status</span>
        <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/20 ml-auto">Time</span>
      </div>

      {/* Transaction Rows */}
      <div className="max-h-[280px] overflow-y-auto dark-scrollbar">
        <AnimatePresence mode="popLayout">
          {sorted.map((tx) => (
            <motion.div
              key={tx.id}
              initial={{ opacity: 0, x: -8 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 8 }}
              transition={{ duration: 0.2, ease: 'easeOut' }}
              className={`flex items-center gap-4 px-5 py-2.5 transition-colors duration-150 border-l-2 ${
                tx.status === 'PROCESSING'
                  ? 'border-l-cyan-500/60 bg-cyan-500/[0.02]'
                  : tx.status === 'ERROR'
                  ? 'border-l-rose-500/60 bg-rose-500/[0.02]'
                  : 'border-l-transparent hover:bg-white/[0.015]'
              }`}
            >
              <span className="text-[11px] font-mono font-medium text-white/60 w-[100px] truncate">
                {tx.id}
              </span>
              <div className="w-[100px]">
                <span
                  className={`px-2 py-0.5 rounded-md text-[10px] font-medium border ${
                    TYPE_BADGE[tx.type] || 'bg-white/5 text-white/50 border-white/10'
                  }`}
                >
                  {tx.type.replace('_', ' ')}
                </span>
              </div>
              <div className="w-[80px]">
                <div className="flex items-center gap-[3px]">
                  {STAGES.map((st) => (
                    <div
                      key={st}
                      className={`w-[6px] h-[6px] rounded-full transition-all duration-300 ${
                        tx.completedStages.includes(st)
                          ? 'bg-emerald-500'
                          : tx.failedStage === st
                          ? 'bg-rose-500'
                          : tx.stage === st && tx.status === 'PROCESSING'
                          ? 'bg-cyan-400 animate-pulse'
                          : 'bg-white/10'
                      }`}
                    />
                  ))}
                </div>
              </div>
              <div className="w-[60px]">
                {tx.status === 'SUCCESS' && (
                  <span className="px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 text-[10px] font-semibold uppercase tracking-wider">
                    Done
                  </span>
                )}
                {tx.status === 'ERROR' && (
                  <span className="px-2 py-0.5 rounded-md bg-rose-500/10 text-rose-400 text-[10px] font-semibold uppercase tracking-wider">
                    Failed
                  </span>
                )}
                {tx.status === 'PROCESSING' && (
                  <span className="px-2 py-0.5 rounded-md bg-cyan-500/10 text-cyan-400 text-[10px] font-semibold uppercase tracking-wider flex items-center gap-1">
                    <span className="w-1 h-1 rounded-full bg-cyan-400 animate-pulse" />
                    Active
                  </span>
                )}
              </div>
              <span className="text-[10px] font-mono text-white/25 ml-auto tabular-nums">
                {timeAgo(tx.timestamp)}
              </span>
            </motion.div>
          ))}
        </AnimatePresence>
        {sorted.length === 0 && (
          <div className="px-5 py-10 text-center">
            <span className="text-[11px] text-white/20">No transactions yet</span>
          </div>
        )}
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════════════════════
   KAFKA LOG PANEL
   ═══════════════════════════════════════════════════════════════════ */

const LOG_CLR = {
  ERROR: 'text-red-400',
  WARN: 'text-yellow-400',
  KAFKA: 'text-purple-400',
  INGEST: 'text-emerald-400',
  DISPATCHER: 'text-cyan-400',
  SCENARIO: 'text-sky-400',
  PAYLOAD: 'text-amber-400',
  CONNECT: 'text-violet-400',
  EVENT_STORE: 'text-teal-400',
};

function LogLine({ msg, ts }) {
  const parts = msg.split(' >> ');
  const prefix = parts[0]?.trim() || '';
  const rest = parts.length > 1 ? parts.slice(1).join(' >> ') : msg;

  return (
    <div className="flex gap-2 leading-5 text-[11px] font-mono">
      <span className="text-white/15 shrink-0 tabular-nums">
        {new Date(ts).toTimeString().split(' ')[0]}.{String(new Date(ts).getMilliseconds()).padStart(3, '0')}
      </span>
      <span className={`shrink-0 font-semibold w-[80px] ${LOG_CLR[prefix] || 'text-white/30'}`}>{prefix}</span>
      <span className="text-white/35 break-all">{rest}</span>
    </div>
  );
}

function KafkaLogPanel() {
  const logs = useDashboardStore((s) => s.logs);
  const run = useDashboardStore((s) => s.running);
  const ref = useRef(null);

  useEffect(() => {
    if (ref.current) ref.current.scrollTop = ref.current.scrollHeight;
  }, [logs]);

  return (
    <div className="bg-[#060A13] border border-white/[0.06] rounded-2xl overflow-hidden">
      {/* Terminal Header */}
      <div className="flex items-center gap-3 px-5 py-3 border-b border-white/[0.04] bg-white/[0.01]">
        <div className="flex items-center gap-1.5">
          <div className="w-2.5 h-2.5 rounded-full bg-red-500/40" />
          <div className="w-2.5 h-2.5 rounded-full bg-yellow-500/40" />
          <div className="w-2.5 h-2.5 rounded-full bg-green-500/40" />
        </div>
        <span className="text-[10px] font-mono text-white/20">$ gbm-pipeline —logs --follow</span>
        <div className="flex items-center gap-1.5 ml-auto">
          {run ? (
            <>
              <span className="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />
              <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-emerald-400/60">Live</span>
            </>
          ) : (
            <span className="text-[9px] font-semibold uppercase tracking-[0.15em] text-white/15">Paused</span>
          )}
          <span className="text-[10px] font-mono text-white/10 tabular-nums">{logs.length}</span>
        </div>
      </div>

      {/* Log Content */}
      <div ref={ref} className="max-h-[200px] overflow-y-auto terminal-scrollbar px-5 py-2">
        {logs.map((log) => (
          <LogLine key={log.id} msg={log.message} ts={log.timestamp} />
        ))}
        {logs.length > 0 && (
          <div className="flex items-center gap-1 mt-0.5">
            <span className="text-emerald-400/40 text-[11px] font-mono">▸</span>
            <span className="w-[6px] h-[14px] bg-emerald-400/50 animate-blink" />
          </div>
        )}
        {logs.length === 0 && (
          <div className="py-6 text-center">
            <span className="text-[11px] text-white/10 font-mono">Waiting for events...</span>
          </div>
        )}
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════════════════════
   VIEW SWITCHER
   ═══════════════════════════════════════════════════════════════════ */

function ViewSwitcher({ active, onChange }) {
  const tabs = [
    { id: 'pipeline', label: 'Pipeline' },
    { id: 'incidents', label: 'Incidents' },
  ];

  return (
    <div className="bg-white/[0.02] border border-white/[0.06] rounded-xl p-1 flex items-center gap-0.5">
      {tabs.map((tab) => (
        <button
          key={tab.id}
          onClick={() => onChange(tab.id)}
          className={`relative px-5 py-2 rounded-lg text-[11px] font-semibold uppercase tracking-[0.1em] transition-colors duration-200 cursor-pointer z-10 ${
            active === tab.id ? 'text-white' : 'text-white/30 hover:text-white/50'
          }`}
        >
          {active === tab.id && (
            <motion.div
              layoutId="tab-indicator"
              className="absolute inset-0 bg-white/[0.06] border border-white/[0.08] rounded-lg"
              transition={{ type: 'spring', bounce: 0.15, duration: 0.4 }}
            />
          )}
          <span className="relative z-10">{tab.label}</span>
        </button>
      ))}
    </div>
  );
}

